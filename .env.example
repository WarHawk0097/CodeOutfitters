# CodeOutfitters — environment contract (names only, NEVER commit real values).
#
# Privileged/server-only variables (NO NEXT_PUBLIC_ prefix, never imported by a
# Client Component, never printed): SUPABASE_SECRET_KEY, RESEND_API_KEY,
# RESEND_WEBHOOK_SECRET.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only service-role key — the sole inquiry write path
SUPABASE_SECRET_KEY=

# --- Inquiry backend (server-only) ---
INQUIRY_IP_HASH_SALT=
INQUIRY_RATE_LIMIT_IP=
INQUIRY_RATE_LIMIT_EMAIL=
INQUIRY_RATE_LIMIT_WINDOW_MS=
# Local/test repository selection ONLY (e.g. "pglite"). Never NEXT_PUBLIC_.
# Production fails closed if privileged config is missing; never defaults to test.
INQUIRY_REPOSITORY_MODE=

# --- Email (Resend; server-only secrets) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=
EMAIL_REPLY_TO=
INTERNAL_INQUIRY_TO=
