# =============================================================================
# CodeOutfitters local environment template
# =============================================================================
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Do not commit real secrets.
#
# Security 1 (2026-06-16) — Anthropic key
# ---------------------------------------
# `NEXT_PUBLIC_ANTHROPIC_API_KEY` is DEPRECATED and FORBIDDEN. The
# frontend no longer holds the Anthropic API key. Proposals are
# generated by a Cloudflare Worker that holds the server-side
# `ANTHROPIC_API_KEY` secret. The browser only knows the public
# Worker URL.
#
# Security 2 (2026-06-16) — Admin auth
# ------------------------------------
# `NEXT_PUBLIC_ADMIN_PASSWORD` is DEPRECATED as a real security
# boundary. The real admin protection is **Cloudflare Access** in
# front of `/admin/*` on the deployed site. The local client-side
# password check in `app/admin/layout.tsx` is convenience-only and is
# explicitly labeled as such. The owner must configure Cloudflare
# Access before any non-internal deploy.
#
# Security 4 (2026-06-16) — n8n form proxy
# ----------------------------------------
# `NEXT_PUBLIC_N8N_WEBHOOK_URL` is DEPRECATED and FORBIDDEN. The
# browser no longer holds the n8n webhook URL or any n8n secret. All
# public forms (contact, quote, newsletter, booking) post to a
# Cloudflare Worker (the forms proxy), which adds the per-form secret
# header server-side and forwards to the correct n8n webhook URL.
# The browser only knows `NEXT_PUBLIC_FORMS_WORKER_URL`. The n8n
# URLs and the per-form secrets are server-side only.
#
# The Worker env vars (`ALLOWED_ORIGIN`, `N8N_*_WEBHOOK_URL`,
# `N8N_*_SECRET`, `ANTHROPIC_API_KEY`) are bound via `wrangler secret
# put` or the Cloudflare dashboard. They do NOT live in this file.
# See `repo-research/SECURITY_4_N8N_SECRET_NOTES.md` for the owner-side
# setup steps and the rollback plan.
# =============================================================================

# ---- Frontend (Cloudflare Pages) ----

# Supabase (anon key only; RLS will be enabled in Security 3).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Worker URL for proposal generation (Security 1).
# The Worker holds the Anthropic API key server-side as ANTHROPIC_API_KEY.
# Example: https://anthropic-proposal-proxy.<account>.workers.dev
NEXT_PUBLIC_PROPOSAL_WORKER_URL=https://your-worker-subdomain.workers.dev

# Cloudflare Worker URL for public form submissions (Security 4).
# The Worker holds the per-form n8n secrets server-side. The browser
# only knows this public Worker URL. Example:
# https://n8n-form-proxy.<account>.workers.dev
NEXT_PUBLIC_FORMS_WORKER_URL=https://your-forms-worker-subdomain.workers.dev

# Cloudflare Worker URL for the booking reservation (Booking B).
# The Worker holds the Supabase `service_role` key server-side and
# calls `supabase.rpc('reserve_slot', ...)` against
# `public.reserve_slot(p_date date, p_time text, p_booking jsonb)
# returns uuid`. The Worker is the only path that writes to `bookings`
# and `available_slots.is_booked` after Security 3 RLS is in place.
# The browser never calls `reserve_slot` directly; anon is never
# granted EXECUTE on `reserve_slot`. The Worker may optionally forward
# the same payload to the n8n booking webhook (server-side, with the
# per-form secret) so the operator still gets a notification. The
# booking form posts here; the contact / quote / newsletter forms
# continue to post to `NEXT_PUBLIC_FORMS_WORKER_URL`. Example:
# https://booking-reservation-worker.<account>.workers.dev
NEXT_PUBLIC_BOOKING_WORKER_URL=https://your-booking-worker-subdomain.workers.dev

# Optional: Tawk live chat.
NEXT_PUBLIC_TAWK_PROPERTY_ID=your-tawk-property-id

# =============================================================================
# DEPRECATED — DO NOT USE
# =============================================================================
#
# `NEXT_PUBLIC_ANTHROPIC_API_KEY` was the previous client-side key. The
# static export would inline it into every visitor's bundle. That is
# gone as of Security 1 (2026-06-16). Leaving the line commented here
# so anyone migrating from older docs knows not to set it.
#
# NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key   # DEPRECATED; do not set.
#
# `NEXT_PUBLIC_ADMIN_PASSWORD` was the previous client-side admin
# "password". The static export would inline it into every visitor's
# bundle, and the `localStorage` flag check is trivially bypassable.
# That is gone as a real security boundary as of Security 2
# (2026-06-16). Cloudflare Access is the real admin boundary. The
# local client-side gate is convenience-only and is explicitly labeled
# as such in `app/admin/layout.tsx`. Leaving the line commented here
# for migration clarity. If you do not have a Cloudflare Access app
# set up yet, you may keep this var set so the local convenience gate
# still works; it just does not provide security.
#
# NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password   # DEPRECATED as security; convenience-only if set.
#
# `NEXT_PUBLIC_N8N_WEBHOOK_URL` was the previous client-side n8n
# webhook URL. The static export would inline it into every visitor's
# bundle. That is gone as of Security 4 (2026-06-16). The browser
# now posts to the forms Worker (`NEXT_PUBLIC_FORMS_WORKER_URL`).
# Leaving the line commented here for migration clarity.
#
# NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-id   # DEPRECATED; do not set.
